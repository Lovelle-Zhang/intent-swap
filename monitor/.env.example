# Monitor server env vars — copy to .env on the host, fill in real values.
# .env is auto-loaded by dotenv at startup.

# Shared secret with Vercel's /api/orders proxy. Must match exactly.
INTERNAL_API_KEY=replace_with_a_long_random_string

# Wallet that calls vault.executeOrder. Must equal the vault's keeper().
KEEPER_PRIVATE_KEY=0x...

# Optional: override default Arbitrum RPC
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Email — https://resend.com (HTTP API; not blocked by GFW from CN hosts).
RESEND_API_KEY=re_...
# Verify a domain in Resend to use your own sender; otherwise use onboarding@resend.dev.
RESEND_FROM=Intent Swap <onboarding@resend.dev>

# WeChat push via Server Chan (sctapi.ftqq.com).
SCT_KEY=

# Web Push (VAPID). Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:ops@example.com

# Port (default 3002 locally; Railway/Render inject PORT automatically).
PORT=3002

# Persistent data directory for lowdb JSON files. Defaults to "." (cwd) for
# local dev + the legacy Aliyun deploy. On Railway, set to "/data" and attach
# a volume mounted at /data so orders.json survives container restarts.
DATA_DIR=.
