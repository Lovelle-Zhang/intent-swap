# OpenAI API Key (for intent parsing) — server only
OPENAI_API_KEY=your_openai_api_key_here

# WalletConnect Project ID (for RainbowKit) — public
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Monitor service URL (e.g. https://api.your-domain.com/swap-orders) — server only.
# The frontend calls /api/orders, which is a server-side proxy that forwards here.
MONITOR_URL=https://api.your-domain.com/swap-orders

# Shared secret between this Next.js app and the monitor service — server only.
# Generate with: openssl rand -hex 32
# Must match INTERNAL_API_KEY set on the monitor server.
INTERNAL_API_KEY=replace_with_a_long_random_string

# Subscription check endpoint (defaults to api.o-sheepps.com/subscriptions/check)
SUBSCRIPTION_CHECK_URL=https://api.your-domain.com/subscriptions/check

# Paywall gate — set to "0" to enforce subscription on /api/orders and the
# conditional-order page. Any other value (or unset) treats conditional
# orders as free during beta. Use the public variant for the client-side
# gate in src/app/conditional-order/page.tsx.
FREE_TIER=
NEXT_PUBLIC_FREE_TIER=

# Interactive Hosted Sandbox — Delivery 1 (names only; do not reuse legacy credentials)
# Public Supabase Auth configuration.
NEXT_PUBLIC_SUPABASE_URL=https://your-sandbox-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_sandbox_publishable_key

# Server-only pooled Postgres URL for a dedicated login role that may assume
# zenfix_app. The login role must not be superuser, BYPASSRLS, or service_role.
SUPABASE_DATABASE_URL=postgresql://dedicated_role:replace_me@host:6543/postgres

# Hosted profiles fail closed when Postgres is unavailable. Local JSON remains
# valid only for test/development profiles and is never a hosted fallback.
ZENFIX_STORAGE_BACKEND=postgres
ZENFIX_DEPLOYMENT_PROFILE=hosted_sandbox
ZENFIX_PRODUCT_SURFACE=zenfix
ZENFIX_EXECUTION_MODE=sandbox
ZENFIX_REAL_FUNDING_EXECUTION_ENABLED=0
ZENFIX_APP_ORIGIN=http://localhost:3000
