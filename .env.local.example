# OpenAI API Key (for intent parsing) — server only
OPENAI_API_KEY=your_openai_api_key_here

# WalletConnect Project ID (for RainbowKit) — public
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Gelato Relay API Key (for automated execution) — server only
GELATO_RELAY_API_KEY=your_gelato_api_key_here

# Monitor service URL (e.g. https://api.your-domain.com/swap-orders) — server only.
# The frontend calls /api/orders, which is a server-side proxy that forwards here.
MONITOR_URL=https://api.your-domain.com/swap-orders

# Shared secret between this Next.js app and the monitor service — server only.
# Generate with: openssl rand -hex 32
# Must match INTERNAL_API_KEY set on the monitor server.
INTERNAL_API_KEY=replace_with_a_long_random_string

# Subscription check endpoint (defaults to api.o-sheepps.com/subscriptions/check)
SUBSCRIPTION_CHECK_URL=https://api.your-domain.com/subscriptions/check
