# Backend Environment Variables

# Claude API key for intent parsing
CLAUDE_API_KEY=your_claude_api_key_here

# Wallet private key (TESTNET ONLY - never use real funds)
PRIVATE_KEY=your_testnet_private_key_here

# Arbitrum Sepolia RPC URL
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# 1inch API key (optional, only needed if not using mock mode)
ONEINCH_API_KEY=your_1inch_api_key_here

# Mock mode (set to true to simulate swaps without real blockchain calls)
MOCK_MODE=true

# Server port
PORT=3001
